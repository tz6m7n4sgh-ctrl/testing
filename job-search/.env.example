# LinkedIn OAuth — create app at https://developer.linkedin.com
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# Full URL where LinkedIn will redirect after login (must match your LinkedIn app config)
# Local dev:      http://localhost:3000/auth/callback
# Railway:        https://your-app.up.railway.app/auth/callback
REDIRECT_URI=http://localhost:3000/auth/callback

# Random string for signing sessions — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-something-random

# Optional — defaults to 3000
PORT=3000
