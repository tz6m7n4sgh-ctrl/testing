# LinkedIn OAuth — create app at https://developer.linkedin.com
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# Full URL where LinkedIn will redirect after login (must match your LinkedIn app config)
# Local dev:      http://localhost:3000/auth/callback
# Railway:        https://your-app.up.railway.app/auth/callback
REDIRECT_URI=http://localhost:3000/auth/callback

# Random string for signing sessions — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-something-random

# Optional — defaults to 3000
PORT=3000

# Optional — enables JSearch (RapidAPI) for UAE / Gulf / global on-site jobs.
# Free tier: subscribe to JSearch at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# (~200 requests/month free), then paste your RapidAPI key here.
RAPIDAPI_KEY=

# Optional — Stage 1 profile understanding upgrades (app works free without these):
#   GITHUB_TOKEN   raises GitHub API rate limits for skill extraction (free PAT, read-only)
#   BRAVE_API_KEY  enables web-reference search (Brave Search API free tier)
#   ANTHROPIC_API_KEY enables Claude for the cover-letter generator (and future AI features)
#   ANTHROPIC_MODEL  optional — defaults to claude-opus-4-8; set to claude-haiku-4-5 for lowest cost
GITHUB_TOKEN=
BRAVE_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
