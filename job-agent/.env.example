# ---- Server ----
PORT=3000
# Secret used to sign session cookies. Set to a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string
# Where the JSON database is stored.
DB_FILE=./data/db.json
# Public base URL of the app (used to build the OAuth redirect URI).
# Local dev: http://localhost:3000  |  Production: https://your-domain
BASE_URL=http://localhost:3000

# ---- LinkedIn "Sign in with LinkedIn using OpenID Connect" ----
# Create an app at https://www.linkedin.com/developers/apps
# Add the "Sign In with LinkedIn using OpenID Connect" product.
# Set the Authorized redirect URL to:  ${BASE_URL}/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# If LinkedIn vars are empty, the app still runs and offers a "demo login"
# so you can try everything locally without registering an app.
